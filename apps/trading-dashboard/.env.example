# =====================================================
# Variables de entorno — CDI Trading Dashboard
# Copia este archivo como .env.local y completa los valores
# =====================================================

# --- Supabase (auth + DB) ---
# Obtener en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# --- Datos de mercado (opcional) ---
# Yahoo Finance (no oficial) se usa por defecto sin key.
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
# Polygon.io (requiere plan pago para snapshots)
POLYGON_KEY=

# --- Miniaturas (Gemini 2.5 Flash Image) ---
# Obtener en: https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# Lista blanca de emails autorizados a usar /miniaturas
# Separados por comas, sin espacios. Los emails deben
# existir como usuarios en Supabase Auth.
MINIATURAS_ALLOWED_EMAILS=tu@email.com
